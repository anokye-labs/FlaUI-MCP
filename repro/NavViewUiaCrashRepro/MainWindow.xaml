<Window
    x:Class="NavViewUiaCrashRepro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NavView UIA Crash Repro">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar (matches crashing Amplifier version exactly) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <TextBlock x:Name="AppTitleText"
                       Text="Repro"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       AutomationProperties.Name="Repro title bar"/>
        </Grid>

        <!-- NavigationView with static items (matches crashing Amplifier version) -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneTitle="Chats"
                        SelectionChanged="NavView_SelectionChanged"
                        AutomationProperties.Name="Main navigation">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Refactor auth module"
                                   Tag="chat1"
                                   AutomationProperties.Name="Chat: Refactor auth module">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Debug CI pipeline"
                                   Tag="chat2"
                                   AutomationProperties.Name="Chat: Debug CI pipeline">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Design API schema"
                                   Tag="chat3"
                                   AutomationProperties.Name="Chat: Design API schema">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator/>
                <NavigationViewItem Content="New Chat"
                                   Tag="newchat"
                                   AutomationProperties.Name="Start new chat">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE710;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Content area -->
            <Grid Padding="24" AutomationProperties.Name="Chat content area">
                <StackPanel x:Name="WelcomePanel"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="8">
                    <TextBlock x:Name="ContentTitle"
                               Text="Welcome"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="ContentSubtitle"
                               Text="Select a chat session or start a new one."
                               FontSize="14"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
