<Window
    x:Class="NavViewUiaCrashRepro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="NavView UIA Crash Repro">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom title bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" Padding="16,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="&#xE700;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <TextBlock Grid.Column="1" Text="NavView UIA Crash Repro"
                       VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
        </Grid>

        <NavigationView x:Name="NavView" Grid.Row="1"
                         AutomationProperties.AutomationId="NavView_Main"
                         IsBackButtonVisible="Collapsed"
                         IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Home" Tag="home">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Browse" Tag="browse">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library"/>
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge Value="3"/>
                    </NavigationViewItem.InfoBadge>
                    <NavigationViewItem.MenuItems>
                        <NavigationViewItem Content="Sub Item 1" Tag="sub1"/>
                        <NavigationViewItem Content="Sub Item 2" Tag="sub2"/>
                    </NavigationViewItem.MenuItems>
                </NavigationViewItem>
                <NavigationViewItem Content="Settings" Tag="settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="16,8,16,8">
            <Button Content="Trigger UIA Enumeration"
                    AutomationProperties.AutomationId="btn_trigger_uia"
                    Click="TriggerUiaEnumeration_Click"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Text="Ready"/>
        </StackPanel>
    </Grid>
</Window>
