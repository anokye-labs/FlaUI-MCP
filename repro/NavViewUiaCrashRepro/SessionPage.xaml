<Page
    x:Class="NavViewUiaCrashRepro.SessionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with InfoBadge (matches Amplifier MainPage pattern) -->
        <Grid Grid.Row="0" Padding="12,6"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="SessionTitle"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <InfoBadge Grid.Column="1"
                       Margin="6,0,0,0"
                       VerticalAlignment="Center"
                       Style="{StaticResource AttentionIconInfoBadgeStyle}"/>
        </Grid>

        <!-- Placeholder content -->
        <ListView Grid.Row="1"
                  SelectionMode="None"
                  Padding="0,4">
            <ListViewItem>
                <TextBlock Text="Message 1: Hello from the session" TextWrapping="Wrap"/>
            </ListViewItem>
            <ListViewItem>
                <TextBlock Text="Message 2: This page has an InfoBadge in the header" TextWrapping="Wrap"/>
            </ListViewItem>
        </ListView>
    </Grid>
</Page>
